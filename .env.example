# Django Secret Key (generate a random one or use any string for local dev)
SECRET_KEY=django-insecure-local-dev-key

# Database (Leave empty for SQLite, or provide URL for Postgres)
# DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Debug Mode
DEBUG=True

# Payment (Razorpay) - Get these from your Razorpay dashboard
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary (Media storage) - Optional for local
CLOUDINARY_URL=

# Email (Optional for local - uses console by default)
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
